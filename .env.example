# Copy this to .env.local and fill in values
# Required variables are uncommented; optional ones are commented out.

# ── Database ──────────────────────────────────────────────────
# Docker (default): postgres://postgres:postgres@localhost:5435/basics
# Neon:             postgres://user:pass@ep-xxx.neon.tech/basics?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5435/basics

# ── Better Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── App URL ──────────────────────────────────────────────────
# Used for building absolute URLs (webhooks, redirects, etc.)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Internal API auth ────────────────────────────────────────
# Secret for server-to-server API calls (e.g. internal auth routes)
# INTERNAL_API_SECRET=

# ── Gateway (LLM routing) ────────────────────────────────────
# GATEWAY_URL=http://localhost:3002
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:3002
# GATEWAY_API_KEY=

# ── AI Provider Keys (optional — only needed if not using gateway) ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── Encryption (for environment variable secrets) ─────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ── Cron (schedule execution) ────────────────────────────────
# Secret for authenticating /api/cron endpoints via Authorization header
# If unset, only localhost requests are allowed in dev
# CRON_SECRET=

# ── Execution ────────────────────────────────────────────────
# Max workflow execution timeout in milliseconds (default: 300000 = 5 min)
# MAX_EXECUTION_TIMEOUT_MS=300000

# ── Search & Scraping Tools (optional) ───────────────────────
# SERPER_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# JINA_API_KEY=

# ── Browser Automation (optional) ────────────────────────────
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# ── S3 / Object Storage (optional — for file uploads) ───────
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# ── Integrations (optional) ──────────────────────────────────
# TRELLO_API_KEY=
# TWILIO_PHONE_NUMBER=
