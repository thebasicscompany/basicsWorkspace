# Copy this to .env.local and fill in values
# Required variables are uncommented; optional ones are commented out.

# ── Database ──────────────────────────────────────────────────
# Docker (default): postgres://postgres:postgres@localhost:5435/basics
# Neon:             postgres://user:pass@ep-xxx.neon.tech/basics?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5435/basics

# ── Better Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── Gateway (LLM routing) ────────────────────────────────────
# GATEWAY_URL=http://localhost:3002
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:3002
# GATEWAY_API_KEY=

# ── Encryption (for environment variable secrets) ─────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ── Cron (schedule execution) ────────────────────────────────
# Secret for authenticating /api/cron endpoints
# If unset, only localhost requests are allowed in dev
# CRON_SECRET=
